# Copy this file to ".env" and fill in your freshly-created tokens.
# Do NOT commit .env to git (see .gitignore).

# Vercel deploy token — create at: https://vercel.com/account/tokens
VERCEL_TOKEN=

# Optional: scope the deploy to a team/org and project
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# GitHub personal access token (only needed if you deploy via the GitHub integration)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=
